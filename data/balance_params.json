  "unit_skills": {
    "description": "兵种技能系统。技能定义在 units.json → skills 数组中，运行时按 type 分发到对应系统处理。",
    "skill_types": {
      "passive": {
        "description": "被动常驻效果，读取 value 字段累加到公式",
        "formula_integration": "atk_buff += skill.value（累加到 unit_ability_bonus）",
        "instances": [
          {
            "id": "enhanced_siege",
            "unit": "jinnu",
            "value": 1.5,
            "note": "攻城加法层+1.5"
          }
        ]
      },
      "terrain_move_modifier": {
        "description": "地形移动力修正，读取 terrain_move_modifier 字典按地形类型覆盖",
        "formula_integration": "move_cost = max(1, base_move_cost + skill.terrain_move_modifier[terrain])",
        "instances": [
          {
            "id": "forest_march",
            "unit": "hufu_qibing",
            "modifier": {
              "forest": -1
            }
          },
          {
            "id": "mountain_march",
            "unit": "shenxi_zhishi",
            "modifier": {
              "mountain": -2
            }
          }
        ]
      },
      "combat_on_kill": {
        "description": "击杀时触发效果，读取 recover_ratio 字段",
        "formula_integration": "on_kill: hp += max_hp × skill.recover_ratio",
        "instances": [
          {
            "id": "wuzu_recover",
            "unit": "wuzu",
            "recover_ratio": 0.05
          }
        ]
      },
      "move_after_attack": {
        "description": "攻击后可继续移动，读取 attack_move_cost 和 per_turn_limit",
        "formula_integration": "on_attack: remaining_mp -= skill.attack_move_cost; if remaining_mp > 0 and attacks_this_turn < skill.per_turn_limit: can_continue_move",
        "instances": [
          {
            "id": "hit_and_run",
            "unit": "liaodong_gongqi",
            "attack_move_cost": 2,
            "per_turn_limit": 1
          }
        ]
      }
    }
  },
