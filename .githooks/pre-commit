#!/usr/bin/env python
import os, sys, re, json

# 硬编码扫描白名单：只扫高敏感目录（系统逻辑与 AI 决策），避免误伤
# 测试 fixture、autoload 初始化代码或 GUT 用例。如果未来需要扩大覆盖范围，
# 修改下方 HARDCODE_SCAN_DIRS 即可。
HARDCODE_SCAN_DIRS = ['scripts/systems', 'scripts/ai']

# 注意：这些正则模式可能产生误报（如测试代码、数据加载初始化）。可根据项目实际情况调整。
HARDCODE_PATTERNS = [
    r'(attack|defense|speed)\s*=\s*\d+',      # 直接赋值属性
    r'faction\s*==\s*"[a-z]+"',               # 字符串国家比较
    r'DataManager\.get_[a-z]+\(\)\s*[+\-*/]\s*\d+' # 数据 + 魔法数字
]

def check_hardcode(file_path):
    with open(file_path, 'r', encoding='utf-8') as f:
        lines = f.readlines()
    issues = []
    for i, line in enumerate(lines, 1):
        for pat in HARDCODE_PATTERNS:
            if re.search(pat, line):
                issues.append(f"{file_path}:{i}: 疑似硬编码：{line.strip()}")
    return issues

def validate_json(file_path):
    try:
        with open(file_path, 'r', encoding='utf-8') as f:
            data = json.load(f)
        # 检查常见必填字段（以 units 为例）
        if 'units' in file_path:
            for unit in data if isinstance(data, list) else data.get('units', []):
                for field in ['id', 'attack', 'defense']:
                    if field not in unit:
                        return [f"{file_path}: 单位缺少必要字段 '{field}'"]
        # TODO: 阶段 0 末锁定 schema 后，启用对 frozen schema 的合规检查（决策 #1）
        # schema = json.load(open('docs/schemas/frozen_schema.json'))
        # validate_against_schema(data, schema)
        return []
    except Exception as e:
        return [f"{file_path}: JSON 解析失败 - {e}"]

if __name__ == "__main__":
    all_issues = []
    # 硬编码扫描：仅 HARDCODE_SCAN_DIRS 内的 .gd 文件
    for scan_dir in HARDCODE_SCAN_DIRS:
        if not os.path.isdir(scan_dir):
            continue
        for root, dirs, files in os.walk(scan_dir):
            for file in files:
                if file.endswith('.gd'):
                    all_issues.extend(check_hardcode(os.path.join(root, file)))
    # JSON 校验：data/ 下所有 .json 文件
    if os.path.isdir('data'):
        for root, dirs, files in os.walk('data'):
            for file in files:
                if file.endswith('.json'):
                    all_issues.extend(validate_json(os.path.join(root, file)))

    if all_issues:
        print("=== 提交拦截：发现以下问题 ===")
        for issue in all_issues:
            print(issue)
        sys.exit(1)
    print("[OK] 硬编码与 JSON 校验通过")
