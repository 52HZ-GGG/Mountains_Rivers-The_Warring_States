#!/usr/bin/env python3
# 文档完整性由 PR review 把关，不再放入自动钩子，避免改章节标题就被误伤。
import os, sys, re

def check_asset_names():
    issues = []
    pattern = re.compile(r'^(tile|unit|ui)_[a-z]+(_[a-z0-9]+)*\.png$')
    for root, dirs, files in os.walk('assets/sprites'):
        for file in files:
            if file.endswith('.png') and not pattern.match(file):
                issues.append(f"资产命名不规范: {root}/{file}")
    return issues

if __name__ == "__main__":
    issues = check_asset_names()
    if issues:
        print("=== 推送拦截：发现以下问题 ===")
        for i in issues:
            print(i)
        sys.exit(1)
    print("[OK] 资产命名规范检查通过")
